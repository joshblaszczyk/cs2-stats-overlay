# CS2 Stats Overlay — environment variables
#
# These are ONLY used for development / testing. End users of the packaged
# app should enter their keys via the in-app setup flow instead — the keys
# are encrypted at rest with Electron safeStorage (Windows DPAPI).
#
# To use this file in dev: copy to `.env` and fill in the blanks.
# Never commit `.env` to version control.

# Steam Web API key — https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# FACEIT Open Data API key — https://developers.faceit.com
FACEIT_API_KEY=

# Leetify developer API keys — https://leetify.com/app/developer
# Two keys supported for rate-limit rotation.
LEETIFY_API_KEY=
LEETIFY_API_KEY_2=

# Optional: Steam refresh token for Game Coordinator rank data.
# Set via in-app setup (recommended) or generate once with `node get-token.js`.
STEAM_REFRESH_TOKEN=
