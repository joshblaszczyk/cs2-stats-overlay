{
  "name": "cs2-stats-overlay",
  "version": "0.1.3",
  "description": "CS2 in-game stats overlay aggregating Leetify, csstats.gg, FACEIT, and Steam — FACEIT safe.",
  "homepage": "https://github.com/joshblaszczyk/cs2-stats-overlay",
  "bugs": {
    "url": "https://github.com/joshblaszczyk/cs2-stats-overlay/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/joshblaszczyk/cs2-stats-overlay.git"
  },
  "main": "./src/main/index.js",
  "scripts": {
    "dev": "electron-vite build && electron .",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "setup": "node src/main/gsi-config.js",
    "pack": "electron-vite build && electron-builder --win --dir",
    "dist": "electron-vite build && electron-builder --win",
    "dist:unsigned": "electron-vite build && electron-builder --win",
    "release": "electron-vite build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.cs2stats.overlay",
    "productName": "CS2 Stats Overlay",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "joshblaszczyk",
        "repo": "cs2-stats-overlay"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": true,
      "signtoolOptions": {
        "signingHashAlgorithms": [
          "sha256"
        ],
        "sign": "build/azure-sign.js"
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CS2 Stats Overlay",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp"
    },
    "files": [
      "out/**/*",
      "src/main/**/*",
      "build/icon.*",
      "node_modules/**/*",
      "!node_modules/**/test/**",
      "!node_modules/**/docs/**"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/koffi/**",
      "**/node_modules/steamworks.js/**",
      "**/node_modules/@laihoe/demoparser2/**",
      "**/node_modules/puppeteer-real-browser/**",
      "build/icon.*"
    ]
  },
  "author": "Ecl1px",
  "license": "MIT",
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "@laihoe/demoparser2": "^0.41.1",
    "electron-updater": "^6.8.3",
    "koffi": "^2.15.4",
    "puppeteer-real-browser": "^1.4.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "steamworks.js": "^0.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.1"
  }
}
